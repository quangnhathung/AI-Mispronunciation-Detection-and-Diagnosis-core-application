APP_NAME=MDD Core Application
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# Model checkpoint paths (auto-detected if left empty)
CNN_BILSTM_CTC_CHECKPOINT=
DAB_TRANSFORMER_CHECKPOINT=
WAV2VEC2_CHECKPOINT=
CNN_BILSTM_CTC_CONFIG=

# Model behavior
MODEL_LOAD_ON_STARTUP=false
DEFAULT_MODEL=wav2vec2
DEFAULT_THRESHOLD=0.5

# File upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_AUDIO_FORMATS=wav,mp3,flac,m4a,ogg

# CORS
CORS_ORIGINS=["*"]
